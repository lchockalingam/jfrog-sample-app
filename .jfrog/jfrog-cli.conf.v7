{
  "version": "1",
  "artifactory": {
    "default": {
      "url": "https://<YOUR_INSTANCE>.jfrog.io/artifactory/",
      "user": "<YOUR_USERNAME>",
      "password": "<YOUR_API_KEY_OR_TOKEN>",
      "insecureTls": false,
      "isDefault": true
    }
  },
  "xray": {
    "default": {
      "url": "https://<YOUR_INSTANCE>.jfrog.io/xray/",
      "user": "<YOUR_USERNAME>",
      "password": "<YOUR_API_KEY_OR_TOKEN>",
      "isDefault": true
    }
  }
}
